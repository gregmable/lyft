# Lyft route settings
SOURCE_ADDRESS=350 5th Ave, New York, NY
DESTINATION_ADDRESS=11 Wall St, New York, NY
TARGET_DATETIME=2026-04-15T09:30:00
PASSENGERS=2
PRICE_THRESHOLD=25.00
CHECK_INTERVAL_HOURS=4

# Optional fixed coordinates (skips address geocoding)
# SOURCE_LAT=40.7484405
# SOURCE_LNG=-73.9856644
# DEST_LAT=40.7074918
# DEST_LNG=-74.0112766

# Web scraping mode uses public fare estimate pages (no API credentials required)
SCRAPER_HEADLESS=true
SCRAPER_SLOW_MO_MS=0
SCRAPER_TIMEOUT_MS=60000
SCRAPER_RETRIES=3
SCRAPER_DEBUG_DIR=scrape_debug

# Email alert settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=app_password_here
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# Database file
DATABASE_PATH=lyft_prices.db
